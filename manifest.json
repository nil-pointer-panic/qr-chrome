{
  "manifest_version": 3,
  "name": "QR Code Generator",
  "version": "1.1.0",
  "description": "将当前页面 URL 或自定义文本转换为二维码，支持历史收藏与下载",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
